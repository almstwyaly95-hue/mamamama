rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{adminId} {
      allow read: if signedIn() && (request.auth.uid == adminId || isAdmin());
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /doctor_requests/{requestId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && (request.auth.uid == requestId || isAdmin());
      allow delete: if isAdmin();
    }

    match /consultations/{consultationId} {
      allow read, write: if signedIn();
      match /messages/{messageId} {
        allow read, write: if signedIn();
      }
    }

    match /group_consultations/{messageId} {
      allow read, create, update: if signedIn();
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if signedIn();
    }
  }
}
